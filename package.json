{
  "name": "@numueg/theme-sdk",
  "version": "0.3.2",
  "description": "NUMU Theme SDK — typed hooks, components, and utilities for building NUMU storefront themes",
  "keywords": [
    "numu",
    "theme",
    "sdk",
    "react",
    "hooks",
    "storefront",
    "ecommerce",
    "byot"
  ],
  "license": "MIT",
  "author": "NUMU <hello@numueg.app>",
  "homepage": "https://numueg.app/docs/sdk/overview",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NUMU-IO/numu-theme-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/NUMU-IO/numu-theme-sdk/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./normalize": {
      "types": "./dist/normalize.d.ts",
      "import": "./dist/normalize.mjs",
      "require": "./dist/normalize.cjs"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.mjs",
      "require": "./dist/validation.cjs"
    },
    "./v2-compat": {
      "types": "./dist/v2-compat.d.ts",
      "import": "./dist/v2-compat.mjs",
      "require": "./dist/v2-compat.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "cross-env RUN_SMOKE=1 vitest run",
    "prepublishOnly": "npm run typecheck && npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.10.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
