{
  "name": "@numu/theme-sdk",
  "version": "0.1.0",
  "description": "NUMU Theme SDK — typed hooks, interfaces, and utilities for NUMU storefront themes",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs",
      "types": "./dist/types.d.ts"
    },
    "./normalize": {
      "import": "./dist/normalize.mjs",
      "require": "./dist/normalize.cjs",
      "types": "./dist/normalize.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}